# MongoDB connection URI
MONGO_URI=mongodb://mongodb:27017/chaintrigger

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Birdeye API Key
BIRDEYE_API_KEY=test_api_key

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=test_bot_token

# Polling Intervals (in milliseconds)
# Default Pro: 1h (3600000), Free: 4h (14400000)
POLLING_INTERVAL_PRO_MS=3600000
POLLING_INTERVAL_FREE_MS=14400000
