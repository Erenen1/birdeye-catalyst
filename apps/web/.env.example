# MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017/chaintrigger

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# WalletConnect Project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# App URL (production URL or localhost)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Sphere Pay ────────────────────────────────────────────────────────────────
# API Key — Sphere Dashboard > Settings > API Keys
SPHERE_API_KEY=sk_live_xxxxxxxxxxxx

# Webhook Secret — Sphere Dashboard > Webhooks > Secret
SPHERE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Product ID — Sphere Dashboard > Products (aylık Pro planı)
SPHERE_PRODUCT_ID=prod_xxxxxxxxxxxx
