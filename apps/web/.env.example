# MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017/chaintrigger

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App URL (production URL or localhost)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Solana ────────────────────────────────────────────────────────────────────
# Custom RPC endpoint (Helius, QuickNode, etc.) — mainnet-beta default if not set
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Solana Pay ────────────────────────────────────────────────────────────────
# Treasury wallet — receives all USDC subscription payments
# Generate a fresh keypair: `solana-keygen new`
PAYMENT_WALLET_ADDRESS=YourSolanaTreasuryWalletAddressHere

# ── Birdeye API ────────────────────────────────────────────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
